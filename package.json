{
  "name": "zahpy-business-pro",
  "version": "1.0.0",
  "description": "Zahpy Business Pro desktop application",
  "main": "src/main.js",
  "author": "Zahpy Business Pro",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/styles/tailwind.input.css -o ./src/vendor/tailwind.css --minify",
    "start": "npm run build:css && electron .",
    "smoke:offline": "npm run build:css && electron ./scripts/smoke-offline.cjs",
    "dist": "npm run dist:standalone",
    "dist:standalone": "npm run build:css && electron-builder --win dir --x64 --config.electronDist=node_modules/electron/dist --config.win.signAndEditExecutable=false && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-standalone.ps1",
    "dist:installer": "npm run build:css && electron-builder --win nsis --x64 --publish never --config.electronDist=node_modules/electron/dist",
    "dist:portable": "npm run build:css && electron-builder --win portable --x64"
  },
  "devDependencies": {
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/great-vibes": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fortawesome/fontawesome-free": "^6.4.0",
    "chart.js": "^4.4.0",
    "crypto-js": "^4.1.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "html2pdf.js": "^0.10.1",
    "qrcodejs": "^1.0.0",
    "tailwindcss": "^3.4.17"
  },
  "build": {
    "appId": "com.zahpy.businesspro",
    "productName": "Zahpy Business Pro",
    "directories": {
      "output": "../../outputs"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "ZahpyBusinessPro.exe"
    },
    "nsis": {
      "artifactName": "ZahpyBusinessPro-Setup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zahpy Business Pro"
    },
    "publish": {
      "provider": "github",
      "owner": "AdejojuA",
      "repo": "Zaphyproproject"
    }
  }
}
